DATABASE_PATH=./data/pharmacy.db

# OpenAI
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o

# Cloudinary
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# SMTP (nodemailer)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM="Home Pharmacy <pharmacy@example.com>"

# Daily expiry digest recipient
NOTIFY_EMAIL=

# Shared secret protecting POST /api/cron/check-expiry
# Generate with:  node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
CRON_SECRET=
