DATABASE_PATH=./data/pharmacy.db

# Public origin the app is served from (scheme + host + port, no trailing slash).
# adapter-node uses this to validate same-origin POSTs; without it, form submits
# fail in production with "Cross-site POST form submissions are forbidden".
ORIGIN=http://dreamquest:3133

# Max request body size in bytes for adapter-node. Default is 524288 (512 KB),
# which is too small for photo uploads. /api/extract caps photos at 10 MB.
BODY_SIZE_LIMIT=10485760

# OpenAI
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o

# Cloudinary
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# SMTP (nodemailer)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM="Home Pharmacy <pharmacy@example.com>"

# Daily expiry digest recipient
NOTIFY_EMAIL=

# Shared secret protecting POST /api/cron/check-expiry
# Generate with:  node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
CRON_SECRET=
